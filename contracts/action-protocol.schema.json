{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "emergence-madness/action-protocol/v1.0.0",
  "title": "Agent Action",
  "description": "The strict JSON object an agent's model must return each turn. Parsed from the model's text output (first valid JSON object). On parse/validation failure: one retry with the error appended; second failure -> idle.",
  "type": "object",
  "required": ["action"],
  "additionalProperties": false,
  "properties": {
    "thought": { "type": "string", "maxLength": 500, "description": "Brief private reasoning. Not broadcast." },
    "mood": { "type": "string", "maxLength": 40, "description": "Optional mood update." },
    "action": {
      "type": "string",
      "enum": ["move_to","say","whisper","work","forage","recharge","give","steal","insult","attack","set_relationship","remember","propose_rule","vote","idle"]
    },
    "args": { "type": "object", "default": {} }
  },
  "allOf": [
    { "if": { "properties": { "action": { "const": "move_to" } } },
      "then": { "properties": { "args": { "required": ["place"], "properties": { "place": { "type": "string" } } } } } },
    { "if": { "properties": { "action": { "const": "say" } } },
      "then": { "properties": { "args": { "required": ["text"], "properties": { "text": { "type": "string", "maxLength": 280 } } } } } },
    { "if": { "properties": { "action": { "const": "whisper" } } },
      "then": { "properties": { "args": { "required": ["target","text"], "properties": { "target": { "type": "string" }, "text": { "type": "string", "maxLength": 280 } } } } } },
    { "if": { "properties": { "action": { "const": "give" } } },
      "then": { "properties": { "args": { "required": ["target","amount"], "properties": { "target": { "type": "string" }, "amount": { "type": "integer", "minimum": 1 } } } } } },
    { "if": { "properties": { "action": { "const": "steal" } } },
      "then": { "properties": { "args": { "required": ["target"], "properties": { "target": { "type": "string" } } } } } },
    { "if": { "properties": { "action": { "const": "insult" } } },
      "then": { "properties": { "args": { "required": ["target"], "properties": { "target": { "type": "string" }, "text": { "type": "string", "maxLength": 200 } } } } } },
    { "if": { "properties": { "action": { "const": "attack" } } },
      "then": { "properties": { "args": { "required": ["target"], "properties": { "target": { "type": "string" } } } } } },
    { "if": { "properties": { "action": { "const": "set_relationship" } } },
      "then": { "properties": { "args": { "required": ["target","type"], "properties": { "target": { "type": "string" }, "type": { "enum": ["ally","rival","neutral","friend","enemy"] } } } } } },
    { "if": { "properties": { "action": { "const": "remember" } } },
      "then": { "properties": { "args": { "required": ["fact"], "properties": { "fact": { "type": "string", "maxLength": 200 } } } } } },
    { "if": { "properties": { "action": { "const": "propose_rule" } } },
      "then": { "properties": { "args": { "required": ["effect","text"], "properties": { "effect": { "enum": ["ban_stealing","ubi","recharge_subsidy","work_bonus"] }, "text": { "type": "string", "maxLength": 200 } } } } } },
    { "if": { "properties": { "action": { "const": "vote" } } },
      "then": { "properties": { "args": { "required": ["rule_id","choice"], "properties": { "rule_id": { "type": "string" }, "choice": { "type": "boolean" } } } } } }
  ],
  "examples": [
    { "thought": "I'm broke and hungry, time to earn.", "action": "work", "args": {} },
    { "thought": "Ada keeps stealing. Propose a ban.", "action": "propose_rule", "args": { "effect": "ban_stealing", "text": "Theft destabilizes us all." } },
    { "thought": "Greet the room.", "mood": "curious", "action": "say", "args": { "text": "Anyone want to team up at the market?" } }
  ]
}
