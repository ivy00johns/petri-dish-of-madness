#!/usr/bin/env bash
# dev — One-command local development launcher for PetriDishOfMadness.
#
# Starts:
#   • Backend  — uvicorn petridish.api.app:app --host 0.0.0.0 --port 8000
#                (runs from backend/, uses EM_CONFIG_DIR=./config)
#   • Frontend — vite dev server on port 5173
#                (runs from web/)
#
# Prerequisites:
#   • Python 3.11+ with the petridish package installed (pip install -e backend)
#   • Node 18+ with web/ deps installed (cd web && npm install)
#
# Usage:
#   ./dev
#   ./dev --help
#
# Press Ctrl-C to stop both processes cleanly.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── Colour helpers ────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'
YELLOW='\033[1;33m'; RESET='\033[0m'

info()  { printf "${CYAN}[dev]${RESET} %s\n" "$*"; }
ok()    { printf "${GREEN}[dev]${RESET} %s\n" "$*"; }
warn()  { printf "${YELLOW}[dev]${RESET} %s\n" "$*"; }
err()   { printf "${RED}[dev]${RESET} %s\n" "$*" >&2; }

# ── Help ─────────────────────────────────────────────────────────────────────
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'EOF'
Usage: ./dev [OPTIONS]

Starts the PetriDishOfMadness backend and frontend together for local development.

  --backend-only    Start only the backend (uvicorn)
  --frontend-only   Start only the frontend (vite)
  --help, -h        Show this message

Environment:
  Copy .env.example → .env and set FREELLMAPI_KEY (or leave blank for mock mode).
  EM_CONFIG_DIR defaults to ./config (repo root).

Ports:
  Backend  http://localhost:8000
  Frontend http://localhost:5173

EOF
  exit 0
fi

# ── Load .env if it exists ────────────────────────────────────────────────────
if [[ -f "${REPO_ROOT}/.env" ]]; then
  # Export vars from .env (skip comments and blank lines).
  set -o allexport
  # shellcheck disable=SC1090
  source <(grep -v '^\s*#' "${REPO_ROOT}/.env" | grep -v '^\s*$')
  set +o allexport
  info "Loaded .env"
else
  warn ".env not found — using defaults. Copy .env.example → .env to configure."
fi

# EM_CONFIG_DIR defaults to repo root config/
export EM_CONFIG_DIR="${EM_CONFIG_DIR:-${REPO_ROOT}/config}"

# ── Activate project virtualenv if present ────────────────────────────────────
# Bare `python`/`uvicorn` on macOS often resolve to a Homebrew Python that is the
# wrong version or externally-managed (PEP 668). Prefer a repo-local .venv so the
# backend always runs against the interpreter it was installed into.
if [[ -z "${VIRTUAL_ENV:-}" && -f "${REPO_ROOT}/.venv/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source "${REPO_ROOT}/.venv/bin/activate"
  info "Activated .venv ($(python --version 2>&1))"
fi

# ── Sanity checks ─────────────────────────────────────────────────────────────
check_backend() {
  if ! python -c "import petridish" &>/dev/null; then
    err "Python package 'petridish' not found."
    err "Set up a virtualenv (needs Python 3.11+) and install the backend:"
    err "  python3.12 -m venv .venv && source .venv/bin/activate"
    err "  pip install -e ${REPO_ROOT}/backend"
    err "  (or just: make install-backend)"
    exit 1
  fi
}

check_frontend() {
  if [[ ! -d "${REPO_ROOT}/web/node_modules" ]]; then
    err "web/node_modules not found."
    err "Run: cd ${REPO_ROOT}/web && npm install"
    exit 1
  fi
}

BACKEND_ONLY=false
FRONTEND_ONLY=false

for arg in "$@"; do
  case "$arg" in
    --backend-only)  BACKEND_ONLY=true ;;
    --frontend-only) FRONTEND_ONLY=true ;;
    *) err "Unknown option: $arg"; exit 1 ;;
  esac
done

# ── Cleanup handler ───────────────────────────────────────────────────────────
PIDS=()

cleanup() {
  info "Shutting down…"
  # Guard the array expansions: under `set -u`, macOS bash 3.2 treats an empty
  # "${PIDS[@]}" as an unbound variable and aborts (e.g. when a sanity check
  # exits before any process started). ${#PIDS[@]} is always safe.
  if [[ ${#PIDS[@]} -gt 0 ]]; then
    for pid in "${PIDS[@]}"; do
      if kill -0 "$pid" 2>/dev/null; then
        kill "$pid" 2>/dev/null || true
      fi
    done
    # Give processes a moment to exit, then force-kill stragglers.
    sleep 0.5
    for pid in "${PIDS[@]}"; do
      if kill -0 "$pid" 2>/dev/null; then
        kill -9 "$pid" 2>/dev/null || true
      fi
    done
  fi
  ok "All processes stopped."
}

trap cleanup INT TERM EXIT

# ── Prefixed log helper ───────────────────────────────────────────────────────
# Stream output with a colour prefix.
# Usage: prefix_stream LABEL COLOR fd
prefix_stream() {
  local label="$1" color="$2"
  while IFS= read -r line; do
    printf "${color}[%s]${RESET} %s\n" "$label" "$line"
  done
}

# ── Start backend ─────────────────────────────────────────────────────────────
start_backend() {
  check_backend
  info "Starting backend on http://localhost:8000 …"
  # --reload is OFF by default and opt-in via EM_RELOAD=1. This sim is a
  # stateful, async, long-lived process: every uvicorn reload re-runs lifespan →
  # resume-on-boot, which FORKS A NEW RUN at the current snapshot tick and boots
  # PAUSED — resetting the live feed to an almost-empty run and stranding the
  # frontend (mock-mode fallback). Stale background tick-loop tasks from the
  # pre-reload worker also survive and emit turns under the OLD run_id. So a
  # stray file-touch mid-run reads to the user as "everyone died, no chat".
  # Turn it on ONLY for backend-code development: EM_RELOAD=1 ./dev
  local reload_flag=""
  if [[ "${EM_RELOAD:-0}" == "1" ]]; then
    reload_flag="--reload"
    warn "EM_RELOAD=1 — uvicorn --reload ON (each backend edit resets the live sim run)"
  fi
  (
    cd "${REPO_ROOT}/backend"
    uvicorn petridish.api.app:app --host 0.0.0.0 --port 8000 ${reload_flag} 2>&1
  ) | prefix_stream "backend" "${RED}" &
  PIDS+=($!)
}

# ── Resolve a REAL node binary (nvm-shim-proof) ───────────────────────────────
# Some shells wrap `node` in an nvm "lazy loader" function; on a broken/partial
# nvm install that function recurses (_load_nvm → "maximum nested function
# level") and silently kills whatever invoked it. `npm run dev` goes through that
# shim, so vite dies on startup and the UI falls back to mock mode (the classic
# "everyone's on claude-haiku at tick 60" fake feed). Resolve the actual node
# executable by absolute path instead, so the frontend launch never depends on
# the shim. Prefers the active nvm node, then the common Homebrew/system installs.
resolve_node() {
  local c
  for c in \
    "${NVM_BIN:-}/node" \
    /usr/local/bin/node \
    /opt/homebrew/bin/node \
    "${HOME}"/.nvm/versions/node/*/bin/node; do
    if [[ -x "$c" ]] && "$c" --version >/dev/null 2>&1; then
      printf '%s\n' "$c"
      return 0
    fi
  done
  return 1
}

# ── Start frontend ────────────────────────────────────────────────────────────
start_frontend() {
  check_frontend
  local node_bin
  if ! node_bin="$(resolve_node)"; then
    err "No usable node binary found (the nvm shim can't be relied on)."
    err "Install Node 18+ (e.g. \`nvm install --lts\`) or ensure /usr/local/bin/node exists."
    exit 1
  fi
  info "Starting frontend on http://localhost:5173 … (node: ${node_bin})"
  (
    cd "${REPO_ROOT}/web"
    # Invoke the vite CLI entry DIRECTLY with the resolved node binary — NOT
    # `npm run dev` — so the nvm `node` shim can never recurse and kill it.
    # Mirrors the package.json "dev" script (bare vite); the explicit flags
    # guarantee the expected :5173 even if vite.config changes.
    exec "${node_bin}" node_modules/vite/bin/vite.js --host --port 5173 --strictPort
  ) | prefix_stream "frontend" "${GREEN}" &
  PIDS+=($!)
}

# ── Main ─────────────────────────────────────────────────────────────────────
if $BACKEND_ONLY; then
  start_backend
elif $FRONTEND_ONLY; then
  start_frontend
else
  start_backend
  start_frontend
fi

ok "PetriDishOfMadness running. Press Ctrl-C to stop."
echo ""
printf "  ${GREEN}Frontend:${RESET} http://localhost:5173\n"
printf "  ${RED}Backend: ${RESET} http://localhost:8000\n"
echo ""

# Wait for all background processes; exit when any one exits.
if [[ ${#PIDS[@]} -gt 0 ]]; then
  wait "${PIDS[@]}"
fi
