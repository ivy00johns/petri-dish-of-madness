# ---------------------------------------------------------------------------
# Petri Dish of Madness — Vite environment variables
# Copy this file to .env (or .env.local) and adjust for your deployment.
# ---------------------------------------------------------------------------

# VITE_COFFEE_BUTTON
# Show the "Buy me a coffee" link in the header.
# Default: enabled when this variable is unset.
# Set to "0", "false", or "off" (case-insensitive) to hide it entirely.
# Useful for self-hosted instances that want a clean header.
# VITE_COFFEE_BUTTON=0
