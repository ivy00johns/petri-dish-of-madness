# .gitignore — EmergenceMadness

# ── Claude ────────────────────────────────────────────────────────────────────
!CLAUDE.md
.claude/          # local Claude Code session/workflow artifacts — not shared

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/
env/
.env
*.db
*.sqlite
*.sqlite3

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
web/dist/
web/.vite/
.npmrc

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Docker ────────────────────────────────────────────────────────────────────
# (docker-compose.yml and Dockerfiles ARE committed; data volumes are not)
docker/data/

# ── Run history (W10 / EM-085) ───────────────────────────────────────────────
# Persistent run DB (config world.db_path -> data/run.sqlite) including the
# -wal/-shm sidecars, which the *.sqlite pattern alone would not match.
/data/

# ── Misc ─────────────────────────────────────────────────────────────────────
*.log
coverage/
.pytest_cache/
htmlcov/
.playwright-mcp/
.playwright/
