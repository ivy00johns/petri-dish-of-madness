# .gitignore — EmergenceMadness

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/
env/
.env
*.db
*.sqlite
*.sqlite3

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
web/dist/
web/.vite/
.npmrc

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Docker ────────────────────────────────────────────────────────────────────
# (docker-compose.yml and Dockerfiles ARE committed; data volumes are not)
docker/data/

# ── Misc ─────────────────────────────────────────────────────────────────────
*.log
coverage/
.pytest_cache/
htmlcov/
.playwright-mcp/
.playwright/
