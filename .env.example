# .env.example — Copy to .env and fill in your secrets.
# NEVER commit .env to version control.

# ── FreeLLMAPI ──────────────────────────────────────────────────────────────
# Local OpenAI-compatible proxy aggregating the free tiers of ~24 providers
# (~1.7B free tokens/month). Self-hosted here as the `freellmapi-freellmapi-1`
# Docker container on :3001 (dashboard: http://localhost:3001).
#
# TWO SEPARATE AUTH SURFACES — don't confuse them:
#   • /v1/*  chat + embeddings — what THIS app calls. Auth = the unified
#     "freellmapi-…" bearer token (FREELLMAPI_KEY). No account required.
#   • /api/* dashboard admin (provider keys, model catalog, health + quota) —
#     gated by a session token you mint by POSTing your account email+password
#     to /api/auth/login. That account (the "un/pw") is created once via the
#     dashboard; fill FREELLMAPI_ADMIN_* to let tooling read those endpoints.

# --- Runtime proxy (required) ---
# Base URL for the FreeLLMAPI OpenAI-compatible endpoint:
FREELLMAPI_BASE_URL=http://localhost:3001/v1
# Unified bearer token — dashboard Keys-page header, starts "freellmapi-":
FREELLMAPI_KEY=freellmapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Dashboard admin account (optional — only to query quota/keys/models) ---
# Admin API base = same host, NO /v1 suffix. Log in at POST /api/auth/login
# with email+password → { token }; send it as `Authorization: Bearer <token>`
# to read: GET /api/health (key status + live quotaStates), /api/keys,
# /api/models, /api/fallback/token-usage. Password must be >= 8 chars.
FREELLMAPI_ADMIN_BASE_URL=http://localhost:3001
FREELLMAPI_ADMIN_EMAIL=
FREELLMAPI_ADMIN_PASSWORD=

# ── Ollama (optional, for local models) ─────────────────────────────────────
# Base URL for a local or remote Ollama instance.
# Default (http://localhost:11434/v1) works if Ollama is running locally.
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Direct provider keys (optional) ─────────────────────────────────────────
# Only needed if using the `anthropic` or `gemini` adapters directly
# (i.e. NOT routing through FreeLLMAPI).
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Backend config ───────────────────────────────────────────────────────────
# Directory where the backend looks for profiles.yaml and world.yaml.
# Defaults to ./config relative to the repo root.
EM_CONFIG_DIR=./config

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# Only VITE_*-prefixed vars reach the browser bundle; everything above stays
# server-side. VITE_COFFEE_BUTTON: unset = show the header "Buy me a coffee"
# link; set to "0", "false", or "off" (case-insensitive) to hide it.
# VITE_COFFEE_BUTTON=false
