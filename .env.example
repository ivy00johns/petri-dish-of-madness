# .env.example — Copy to .env and fill in your secrets.
# NEVER commit .env to version control.

# ── FreeLLMAPI ──────────────────────────────────────────────────────────────
# OpenAI-compatible proxy covering ~14 providers (~1.3B free tokens/month).
# Sign up at https://freellmapi.com (or your self-hosted instance).
# Base URL for the FreeLLMAPI OpenAI-compatible endpoint:
FREELLMAPI_BASE_URL=http://localhost:3001/v1
# Bearer token for FreeLLMAPI authentication:
FREELLMAPI_KEY=

# ── Ollama (optional, for local models) ─────────────────────────────────────
# Base URL for a local or remote Ollama instance.
# Default (http://localhost:11434/v1) works if Ollama is running locally.
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Direct provider keys (optional) ─────────────────────────────────────────
# Only needed if using the `anthropic` or `gemini` adapters directly for TEXT
# (i.e. NOT routing through FreeLLMAPI).
ANTHROPIC_API_KEY=
# GEMINI_API_KEY also drives the IMAGE/artwork provider (see Image generation
# below): when set, the Atelier uses Gemini for art, falling back to free
# Pollinations on any failure.
GEMINI_API_KEY=

# ── Image generation (the Atelier) ───────────────────────────────────────────
# Provider precedence: EM_IMAGEGEN_MOCK > Gemini (if GEMINI_API_KEY) >
# Cloudflare (if CF_* set) > Pollinations (free, default, no key).
# EM_IMAGEGEN_GEMINI_MODEL overrides the Gemini image model. NOTE:
# gemini-2.5-flash-image is PAID — its free-tier quota is 0, so an unbilled
# GEMINI_API_KEY 429s and art falls back to Pollinations. Enable billing in
# Google AI Studio to use Gemini for real.
# EM_IMAGEGEN_GEMINI_MODEL=gemini-2.5-flash-image
# Cloudflare Workers AI (optional alternative image provider):
# CF_ACCOUNT_ID=
# CF_API_TOKEN=

# ── Backend config ───────────────────────────────────────────────────────────
# Directory where the backend looks for profiles.yaml and world.yaml.
# Defaults to ./config relative to the repo root.
EM_CONFIG_DIR=./config

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# Only VITE_*-prefixed vars reach the browser bundle; everything above stays
# server-side. VITE_COFFEE_BUTTON: unset = show the header "Buy me a coffee"
# link; set to "0", "false", or "off" (case-insensitive) to hide it.
# VITE_COFFEE_BUTTON=false
